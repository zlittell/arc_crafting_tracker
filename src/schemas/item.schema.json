{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item",
  "description": "Any craftable or upgradeable game item",
  "type": "object",
  "required": ["id", "name", "category"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "weapon",
        "shield",
        "augment",
        "ammunition",
        "weapon_mod",
        "quick_use",
        "key",
        "crafting_material",
        "misc"
      ]
    },
    "subcategory": { "type": "string" },
    "ammo_type": { "type": "string" },
    "slot": { "type": "string" },
    "craft_recipe": {
      "type": "object",
      "required": ["ingredients"],
      "additionalProperties": false,
      "properties": {
        "ingredients": { "$ref": "#/$defs/ingredients" }
      }
    },
    "upgrades": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "ingredients"],
        "additionalProperties": false,
        "properties": {
          "level": { "type": "integer", "minimum": 1 },
          "label": { "type": "string" },
          "ingredients": { "$ref": "#/$defs/ingredients" },
          "perks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["material_id", "quantity"],
        "additionalProperties": false,
        "properties": {
          "material_id": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
