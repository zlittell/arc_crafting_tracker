{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Materials List",
  "description": "A list of crafting materials with an inherited category",
  "type": "object",
  "required": ["category", "materials"],
  "additionalProperties": false,
  "properties": {
    "category": { "type": "string", "const": "crafting_material" },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "craft_recipe": {
            "type": "object",
            "required": ["ingredients"],
            "additionalProperties": false,
            "properties": {
              "ingredients": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["material_id", "quantity"],
                  "additionalProperties": false,
                  "properties": {
                    "material_id": { "type": "string" },
                    "quantity": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
