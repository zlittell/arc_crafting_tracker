{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item List",
  "description": "A list of items sharing a common category (weapons, mods, augments, etc.)",
  "type": "object",
  "required": ["category", "items"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "weapon",
        "shield",
        "augment",
        "ammunition",
        "weapon_mod",
        "quick_use",
        "key",
        "crafting_material",
        "misc"
      ]
    },
    "items": {
      "type": "array",
      "items": { "$ref": "item.schema.json#" }
    }
  }
}
